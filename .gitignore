*.py[cod]
*$py.class
*.so
*.log
*.pot
*.pyc
*.pyo
*.db
*.sqlite3
db.sqlite3
media/
staticfiles/
static/
local_settings.py
venv/
.venv/
ENV/
env/
venv.bak/
env.bak/

# Environment files
#.env
#.env.*

# Database dumps
dump.rdb
*.rdb
*.sql
*.psql

# -----------------------------------------------------------------------------
