# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log
*.node
.npm/
.yarn/
.pnp/
.pnp.js
build/
dist/
coverage/

# Frontend directories
frontend/build/
frontend/dist/
