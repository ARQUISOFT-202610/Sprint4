

DB_NAME=django_db
DB_USER=postgres
DB_PASSWORD=xxxx
DB_HOST=<endpoint_de_rds>
DB_PORT=5432

# ============================================================================
# CloudWatch Logs Configuration (ASR2 - Audit Logs Retention)
# ============================================================================
# Log group names for Django, Celery, and security events
# These are created by terraform/modules/cloudwatch/main.tf
# Retention: 90 days for compliance
AWS_CLOUDWATCH_LOG_GROUP=/arquisoft/django
AWS_CLOUDWATCH_SECURITY_LOG_GROUP=/arquisoft/django/security
AWS_CLOUDWATCH_CELERY_LOG_GROUP=/arquisoft/celery
AWS_CLOUDWATCH_CELERY_FAILURES_LOG_GROUP=/arquisoft/celery/failures
AWS_CLOUDWATCH_RETENTION_DAYS=90

# ============================================================================
# AWS SES Configuration (Email Notifications)
# ============================================================================
# Simple Email Service for sending analysis result notifications
# IMPORTANT: Both sender and recipient emails must be verified in AWS SES console
# In AWS Academy accounts, SES operates in "SANDBOX MODE" - manual verification required
AWS_SES_SENDER_EMAIL=c.ochoao@uniandes.edu.co
AWS_SES_RECIPIENT_EMAIL=c.ochoao@uniandes.edu.co
AWS_SES_SUCCESS_TEMPLATE=analisis-resultado-exito
AWS_SES_FAILURE_TEMPLATE=analisis-resultado-error