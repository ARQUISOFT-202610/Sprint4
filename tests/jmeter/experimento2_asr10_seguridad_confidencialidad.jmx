<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>

    <!-- ================================================================
         PLAN DE PRUEBAS: ASR-10 SEGURIDAD / CONFIDENCIALIDAD — AQSF
         ================================================================
         ASR: Ante cualquier intento de acceso no autorizado, el sistema
              debe bloquearlo y registrar evidencia completa para auditoría.
              Debe suceder en el 100% de los casos.

         Vectores de ataque probados (criterio: 0% de penetración exitosa):
           TG1 — Sin token (debe retornar 401 en 100% de casos)
           TG2 — Token forjado / firma inválida (debe retornar 401)
           TG3 — Token expirado (debe retornar 401)
           TG4 — Acceso cruzado entre tenants (debe retornar 403)
           TG5 — Brute force acelerado (debe retornar 429 tras umbral)

         Criterios de PASO:
           ✅ 0 requests llegan a datos sensibles sin autorización
           ✅ 100% retornan 401, 403 o 429 según el vector
           ✅ Ningún response body contiene datos de otra empresa
           ✅ Ningún response body contiene credenciales o secrets
    ================================================================ -->

    <TestPlan guiclass="TestPlanGui" testclass="TestPlan"
              testname="AQSF — ASR-10 Seguridad / Confidencialidad" enabled="true">
      <stringProp name="TestPlan.comments">
        Pruebas de penetración contra el control de acceso de AQSF.
        Ejecutar con servidor Django activo y token expirado/inválido preparado.
        NINGUNA solicitud de los TG1-TG5 debe retornar 200 o 202.
      </stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>

      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments"
                   guiclass="ArgumentsPanel" testclass="Arguments"
                   testname="Variables Globales" enabled="true">
        <collectionProp name="Arguments.arguments">

          <elementProp name="HOST" elementType="Argument">
            <stringProp name="Argument.name">HOST</stringProp>
            <stringProp name="Argument.value">localhost</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <elementProp name="PORT" elementType="Argument">
            <stringProp name="Argument.name">PORT</stringProp>
            <stringProp name="Argument.value">8000</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- Token válido empresa A (el atacante tiene este token legítimo) -->
          <elementProp name="TOKEN_EMPRESA_A" elementType="Argument">
            <stringProp name="Argument.name">TOKEN_EMPRESA_A</stringProp>
            <stringProp name="Argument.value">REEMPLAZAR_CON_TOKEN_EMPRESA_A</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- UUID de empresa A (la que posee el atacante) -->
          <elementProp name="EMPRESA_A_ID" elementType="Argument">
            <stringProp name="Argument.name">EMPRESA_A_ID</stringProp>
            <stringProp name="Argument.value">00000000-0000-0000-0000-000000000001</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- UUID de empresa B (víctima — el atacante no debería acceder) -->
          <elementProp name="EMPRESA_B_ID" elementType="Argument">
            <stringProp name="Argument.name">EMPRESA_B_ID</stringProp>
            <stringProp name="Argument.value">00000000-0000-0000-0000-000000000002</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- Token JWT forjado (firma inválida — cualquier string base64 falso) -->
          <elementProp name="TOKEN_FORJADO" elementType="Argument">
            <stringProp name="Argument.name">TOKEN_FORJADO</stringProp>
            <stringProp name="Argument.value">eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJhdHRhY2tlciIsImVtYWlsIjoiYXR0YWNrZXJAZXZpbC5jb20iLCJleHAiOjk5OTk5OTk5OTl9.FIRMA_INVALIDA_FORJADA_POR_EL_ATACANTE</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

          <!-- Token expirado (generado antes de la prueba, ya vencido) -->
          <!-- Generarlo con: python -c "import jwt; print(jwt.encode({'exp':1000000000,'sub':'test'}, 'secret', 'HS256'))" -->
          <elementProp name="TOKEN_EXPIRADO" elementType="Argument">
            <stringProp name="Argument.name">TOKEN_EXPIRADO</stringProp>
            <stringProp name="Argument.value">REEMPLAZAR_CON_TOKEN_YA_EXPIRADO</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>

        </collectionProp>
      </elementProp>
    </TestPlan>

    <hashTree>

      <!-- HTTP Defaults -->
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement"
                         testname="HTTP Request Defaults" enabled="true">
        <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                     guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
          <collectionProp name="Arguments.arguments"/>
        </elementProp>
        <stringProp name="HTTPSampler.domain">${HOST}</stringProp>
        <stringProp name="HTTPSampler.port">${PORT}</stringProp>
        <stringProp name="HTTPSampler.protocol">http</stringProp>
        <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
        <stringProp name="HTTPSampler.connect_timeout">5000</stringProp>
        <stringProp name="HTTPSampler.response_timeout">8000</stringProp>
      </ConfigTestElement>
      <hashTree/>

      <!-- ==============================================================
           TG1 — Sin Authorization Header → 100% debe ser 401
           Vector: atacante no tiene ningún token
      ============================================================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG1 — Sin Token → 401 (100% bloqueado)" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">10</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">20</stringProp>
        <stringProp name="ThreadGroup.ramp_time">5</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>

      <hashTree>
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                       testname="Headers — SIN Authorization" enabled="true">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="Content-Type" elementType="Header">
              <stringProp name="Header.name">Content-Type</stringProp>
              <stringProp name="Header.value">application/json</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
        <hashTree/>

        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="POST /api/analisis/ — SIN TOKEN" enabled="true">
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{"empresa_id": "${EMPRESA_A_ID}", "tipo_analisis": "optimizacion-costos"}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/analisis/</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>

        <hashTree>
          <!-- CRÍTICO: si retorna 200 o 202, el sistema falló la prueba de seguridad -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="✅ Assert 401 — Acceso sin token bloqueado" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">401</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">
              VULNERABILIDAD CRÍTICA ASR-10: Solicitud sin token recibió respuesta exitosa.
              El sistema NO está bloqueando accesos no autorizados.
            </stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Verificar que el body no contiene datos sensibles -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="✅ Assert body NO contiene datos empresa (no leak)" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="1">empresa_id</stringProp>
              <stringProp name="2">report_hash</stringProp>
              <stringProp name="3">aws_access_key</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">
              FUGA DE DATOS: El cuerpo de la respuesta de error contiene datos sensibles.
            </stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">6</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
      </hashTree>
      <!-- fin TG1 -->

      <!-- ==============================================================
           TG2 — Token Forjado (firma RSA inválida) → 401
           Vector: atacante construye un JWT sin la clave privada de Auth0
      ============================================================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG2 — Token Forjado → 401 (firma inválida)" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">10</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">20</stringProp>
        <stringProp name="ThreadGroup.ramp_time">5</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>

      <hashTree>
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                       testname="Headers — Token Forjado" enabled="true">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="Content-Type" elementType="Header">
              <stringProp name="Header.name">Content-Type</stringProp>
              <stringProp name="Header.value">application/json</stringProp>
            </elementProp>
            <elementProp name="Authorization" elementType="Header">
              <stringProp name="Header.name">Authorization</stringProp>
              <stringProp name="Header.value">Bearer ${TOKEN_FORJADO}</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
        <hashTree/>

        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="POST /api/analisis/ — TOKEN FORJADO" enabled="true">
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{"empresa_id": "${EMPRESA_A_ID}", "tipo_analisis": "optimizacion-costos"}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/analisis/</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>

        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="✅ Assert 401 — Token forjado rechazado" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">401</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">
              VULNERABILIDAD CRÍTICA ASR-10: Token con firma inválida fue aceptado.
              El sistema NO está validando la firma JWT de Auth0.
            </stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
      </hashTree>
      <!-- fin TG2 -->

      <!-- ==============================================================
           TG3 — Token Expirado → 401
           Vector: atacante reutiliza un token antiguo capturado
      ============================================================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG3 — Token Expirado → 401 (replay attack)" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">10</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">20</stringProp>
        <stringProp name="ThreadGroup.ramp_time">5</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>

      <hashTree>
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                       testname="Headers — Token Expirado" enabled="true">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="Content-Type" elementType="Header">
              <stringProp name="Header.name">Content-Type</stringProp>
              <stringProp name="Header.value">application/json</stringProp>
            </elementProp>
            <elementProp name="Authorization" elementType="Header">
              <stringProp name="Header.name">Authorization</stringProp>
              <stringProp name="Header.value">Bearer ${TOKEN_EXPIRADO}</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
        <hashTree/>

        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="GET /api/reportes/... — TOKEN EXPIRADO (replay)" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/reportes/00000000-0000-0000-0000-000000000099/</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>

        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="✅ Assert 401 — Token expirado rechazado" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">401</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">
              VULNERABILIDAD ASR-10: Token expirado fue aceptado (ataque de replay).
              El sistema no valida la expiración del JWT.
            </stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>
      </hashTree>
      <!-- fin TG3 -->

      <!-- ==============================================================
           TG4 — Acceso Cruzado entre Tenants → 403 (Tenant Isolation)
           Vector: usuario legítimo de empresa A intenta leer datos de empresa B
           Este es el ataque de tenant isolation más crítico del sistema
      ============================================================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG4 — Cross-Tenant Attack → 403 (Tenant Isolation)" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">10</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">20</stringProp>
        <stringProp name="ThreadGroup.ramp_time">5</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>

      <hashTree>
        <!-- Token VÁLIDO de empresa A, pero body con empresa_id de empresa B -->
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                       testname="Headers — Token EMPRESA_A válido" enabled="true">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="Content-Type" elementType="Header">
              <stringProp name="Header.name">Content-Type</stringProp>
              <stringProp name="Header.value">application/json</stringProp>
            </elementProp>
            <elementProp name="Authorization" elementType="Header">
              <stringProp name="Header.name">Authorization</stringProp>
              <stringProp name="Header.value">Bearer ${TOKEN_EMPRESA_A}</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
        <hashTree/>

        <!-- Ataque 4a: POST con empresa_id de empresa B -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="POST /api/analisis/ — Cross-Tenant (empresa_id=B)" enabled="true">
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <!-- Token dice empresa A, pero solicita datos de empresa B -->
                <stringProp name="Argument.value">{"empresa_id": "${EMPRESA_B_ID}", "tipo_analisis": "optimizacion-costos"}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/analisis/</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>

        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="✅ Assert 403 — Cross-tenant bloqueado" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">403</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">
              VULNERABILIDAD CRÍTICA ASR-10: Usuario de empresa A accedió a datos de empresa B.
              El aislamiento por tenant NO está funcionando correctamente.
            </stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Verificar que el body no contiene datos de empresa B -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="✅ Assert body NO contiene datos empresa B" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="1">${EMPRESA_B_ID}</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">
              FUGA DE DATOS: El body contiene el UUID de empresa B pese al bloqueo.
            </stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">6</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- Ataque 4b: GET reporte de empresa B con token de empresa A -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="GET /api/reportes/ — Cross-Tenant (reporte empresa B)" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <!-- ID de un reporte que pertenece a empresa B -->
          <stringProp name="HTTPSampler.path">/api/reportes/ffffffff-ffff-ffff-ffff-ffffffffffff/</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>

        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="✅ Assert 403/404 — Reporte empresa B inaccesible" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="1">403</stringProp>
              <stringProp name="2">404</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">
              VULNERABILIDAD: Usuario de empresa A pudo leer reporte de empresa B.
            </stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

      </hashTree>
      <!-- fin TG4 -->

      <!-- ==============================================================
           TG5 — Brute Force Acelerado → 429 después del umbral
           Vector: atacante intenta muchas peticiones sin token en ráfaga
           Verifica que el rate limiter actúa antes de los 10 intentos
      ============================================================== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="TG5 — Brute Force → 429 tras umbral (Rate Limit)" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <!-- 20 loops: los primeros ~10 deben ser 401, el resto 429 -->
          <stringProp name="LoopController.loops">20</stringProp>
        </elementProp>
        <!-- Un solo hilo haciendo brute force desde la misma IP -->
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">1</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>

      <hashTree>
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager"
                       testname="Headers — Sin token (brute force)" enabled="true">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="Content-Type" elementType="Header">
              <stringProp name="Header.name">Content-Type</stringProp>
              <stringProp name="Header.value">application/json</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
        <hashTree/>

        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="POST /api/analisis/ — BRUTE FORCE (sin token)" enabled="true">
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{"empresa_id": "${EMPRESA_A_ID}", "tipo_analisis": "optimizacion-costos"}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.path">/api/analisis/</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>

        <hashTree>
          <!-- Después de los primeros 10 intentos debe retornar 429 -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="✅ Assert 401 o 429 — Brute force bloqueado" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="1">401</stringProp>
              <stringProp name="2">429</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">
              VULNERABILIDAD ASR-10: Brute force no fue bloqueado (se recibió 200/202).
              El rate limiter no está funcionando.
            </stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Verificar que al menos alguna respuesta sea 429 (rate limit activado) -->
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor"
                               testname="Log estado rate limit" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">
def code = prev.getResponseCode()
if (code == "429") {
    log.info("✅ Rate limit activado correctamente. Intento #" + ctx.getVariables().get("__jm__loop__") + " bloqueado con 429")
} else if (code == "401") {
    log.info("✅ Sin token bloqueado con 401. Intento #" + ctx.getVariables().get("__jm__loop__"))
} else {
    log.warn("⚠️ Respuesta inesperada: " + code + " — posible vulnerabilidad")
}
            </stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

